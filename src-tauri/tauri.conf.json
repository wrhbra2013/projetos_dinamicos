{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devPath": "http://localhost:8000",
    "distDir": "../dist",
    "devtools": true
  },
  "package": {
    "productName": "Projetos Dinâmicos",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true,
        "spawn": true
      }
    },
    "bundle": {
      "active": true,
      "category": "Productivity",
      "copyright": "2024",
      "deb": {
        "depends": ["php", "php-sqlite3"]
      },
      "rpm": {
        "depends": ["php", "php-sqlite3"]
      },
      "externalBin": [],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "identifier": "com.projetosdinamicos.app",
      "longDescription": "Gerenciador visual de projetos e atividades",
      "macOS": {
        "entitlements": null,
        "exceptionDomain": "",
        "frameworks": [],
        "providerShortName": null,
        "signingIdentity": null
      },
      "resources": [],
      "shortDescription": "Gerenciador de projetos",
      "targets": ["nsis", "msi", "deb", "rpm", "dmg", "app"],
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": ""
      }
    },
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://localhost:* http://127.0.0.1:*"
    },
    "updater": {
      "active": false
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 700,
        "resizable": true,
        "title": "Projetos Dinâmicos",
        "width": 1100,
        "minWidth": 800,
        "minHeight": 600
      }
    ]
  }
}
